DATABASE_URL=postgresql://harakapay:harakapay@localhost:5433/harakapay
JWT_SECRET=dev-jwt-secret
PORT=4000
VITE_API_URL=http://localhost:4000/api/v1

# Demo-only shortcuts. Leave unset (or set to anything other than "true")
# for the real reviewer-facing flow. Both default OFF.
# DEMO_SKIP_LOGIN bypasses the cookie session and auto-authenticates every
# request as demo@harakapay.demo (role: approver). Run `pnpm seed` first to
# create that user.
DEMO_SKIP_LOGIN=false
# DEMO_ALLOW_ALL_APPROVALS lets any authenticated user perform approver-only
# bill transitions (approve, reject, schedule, paid).
DEMO_ALLOW_ALL_APPROVALS=false
